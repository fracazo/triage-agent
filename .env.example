# Copy to .env and fill in. .env is git-ignored.
# Free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-3.5-flash when unset).
# e.g. gemini-2.5-flash if the free tier returns 503s on the default.
# GEMINI_MODEL=gemini-2.5-flash
